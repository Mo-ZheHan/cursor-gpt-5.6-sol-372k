  "os": [
    "darwin"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "patch-cursor.js",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "node --check patch-cursor.js",
    "test": "node --test test/*.test.js",
    "verify": "npm run check && npm test",
    "patch:install": "node patch-cursor.js install",
    "patch:status": "node patch-cursor.js status",
    "pack:dry": "cache=$(mktemp -d \"${TMPDIR:-/tmp}/cursor-372k-pack.XXXXXX\") && trap 'rm -rf \"$cache\"' EXIT && npm pack --dry-run --cache \"$cache\""
  }
