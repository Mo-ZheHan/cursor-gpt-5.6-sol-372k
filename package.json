{
  "name": "cursor-gpt-5.6-sol-372k",
  "description": "Unofficial macOS patcher for using GPT-5.6 Sol with a 372K context window in Cursor.",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mo-ZheHan/cursor-gpt-5.6-sol-372k.git"
  },
  "homepage": "https://github.com/Mo-ZheHan/cursor-gpt-5.6-sol-372k#readme",
  "bugs": {
